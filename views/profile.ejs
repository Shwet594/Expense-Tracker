<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile - Expense Tracker</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }
    .glass {
      background: rgba(17, 24, 39, 0.8);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-6 text-white">

  <main class="w-full max-w-6xl glass rounded-2xl p-8 shadow-xl">
    
    <!-- Profile Header -->
    <div class="flex items-center space-x-6 mb-8">
      <div class="w-20 h-20 bg-gradient-to-r from-blue-900 to-blue-400 rounded-full flex items-center justify-center text-white font-bold text-3xl">
        <%= user.username.charAt(0).toUpperCase() %>
      </div>
      <div>
        <h1 class="text-3xl font-bold text-blue-300">Hello, <%= user.username %> 👋</h1>
        <p class="text-gray-400"><%= user.email %></p>
      </div>
    </div>

    <!-- Profile Details -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="glass p-4 rounded-lg">
        <p class="text-gray-400 text-sm">Username</p>
        <p class="text-lg font-semibold"><%= user.username %></p>
      </div>
      <div class="glass p-4 rounded-lg">
        <p class="text-gray-400 text-sm">Email</p>
        <p class="text-lg font-semibold"><%= user.email %></p>
      </div>
    </div>

    <!-- Income & Expense Forms -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      <!-- Income Form -->
      <div class="glass p-6 rounded-lg">
        <h2 class="text-xl font-bold mb-4 text-green-400">Add Income</h2>
        <form action="/users/income/add" method="POST" class="space-y-4">
          <div>
            <label class="block mb-1 text-sm">Category</label>
            <select name="category" class="w-full p-2 rounded-md bg-gray-700 border border-gray-600 focus:outline-none">
              <option value="Salary">Salary</option>
              <option value="Bonus">Bonus</option>
              <option value="Extra">Extra</option>
            </select>
          </div>
          <div>
            <label class="block mb-1 text-sm">Description</label>
            <input type="text" name="description" placeholder="August Salary"
                   class="w-full p-2 rounded-md bg-gray-700 border border-gray-600 focus:outline-none">
          </div>
          <div>
            <label class="block mb-1 text-sm">Amount</label>
            <input type="number" name="amount" placeholder="5000"
                   class="w-full p-2 rounded-md bg-gray-700 border border-gray-600 focus:outline-none">
          </div>
          <div>
            <label class="block mb-1 text-sm">Date</label>
            <input type="date" name="date"
                   class="w-full p-2 rounded-md bg-gray-700 border border-gray-600 focus:outline-none">
          </div>
          <button type="submit"
            class="w-full py-2 bg-green-600 hover:bg-green-700 rounded-lg font-semibold">
            Add Income
          </button>
        </form>
      </div>

      <!-- Expense Form -->
      <div class="glass p-6 rounded-lg">
        <h2 class="text-xl font-bold mb-4 text-red-400">Add Expense</h2>
        <form action="/users/expense/add" method="POST" class="space-y-4">
          <div>
            <label class="block mb-1 text-sm">Category</label>
            <select name="category" class="w-full p-2 rounded-md bg-gray-700 border border-gray-600 focus:outline-none">
              <option value="FixedBills">Fixed Bills</option>
              <option value="Foodandtravel">Food and Travel</option>
              <option value="Groceries">Groceries</option>
              <option value="Miscellaneous">Miscellaneous</option>
            </select>
          </div>
          <div>
            <label class="block mb-1 text-sm">Description</label>
            <input type="text" name="description" placeholder="Lunch at cafe"
                   class="w-full p-2 rounded-md bg-gray-700 border border-gray-600 focus:outline-none">
          </div>
          <div>
            <label class="block mb-1 text-sm">Amount</label>
            <input type="number" name="amount" placeholder="200"
                   class="w-full p-2 rounded-md bg-gray-700 border border-gray-600 focus:outline-none">
          </div>
          <div>
            <label class="block mb-1 text-sm">Date</label>
            <input type="date" name="date"
                   class="w-full p-2 rounded-md bg-gray-700 border border-gray-600 focus:outline-none">
          </div>
          <button type="submit"
            class="w-full py-2 bg-red-600 hover:bg-red-700 rounded-lg font-semibold">
            Add Expense
          </button>
        </form>
      </div>
    </div>

    <!-- Button to go to Transactions Page -->
    <div class="mb-8">
      <a href="/users/All" 
         class="block w-full text-center bg-blue-600 hover:bg-blue-700 py-3 rounded-lg font-medium transition transform hover:scale-105">
        View All Transactions
      </a>
    </div>

    <!-- Logout -->
    <div>
      <a href="/auth/logout" 
         class="block w-full text-center bg-gradient-to-r from-red-700 to-red-500 hover:from-red-800 hover:to-red-600 py-3 rounded-lg font-medium transition transform hover:scale-105">
        Logout
      </a>
    </div>

  </main>

</body>
</html>
