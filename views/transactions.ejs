<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Transactions - Expense Tracker</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }
    .glass {
      background: rgba(17, 24, 39, 0.8);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-6 text-white">

  <main class="w-full max-w-6xl glass rounded-2xl p-8 shadow-xl">

    <h1 class="text-3xl font-bold text-blue-300 mb-6">All Transactions</h1>

    <!-- 🔎 Filter Form -->
    <div class="glass p-6 rounded-lg mb-8">
      <h2 class="text-xl font-bold mb-4 text-blue-400">Filter Transactions</h2>
      <form action="/users/transactions/filter" method="GET" class="grid md:grid-cols-4 gap-4">
        
        <!-- Start Date -->
        <div>
          <label for="startDate" class="block mb-2 text-sm">Start Date</label>
          <input type="date" id="startDate" name="startDate" 
                 class="w-full p-2 rounded-lg bg-gray-900 border border-gray-700 text-white focus:ring-2 focus:ring-blue-500">
        </div>
        
        <!-- End Date -->
        <div>
          <label for="endDate" class="block mb-2 text-sm">End Date</label>
          <input type="date" id="endDate" name="endDate" 
                 class="w-full p-2 rounded-lg bg-gray-900 border border-gray-700 text-white focus:ring-2 focus:ring-blue-500">
        </div>
        
        <!-- Category -->
        <div>
          <label for="category" class="block mb-2 text-sm">Category</label>
          <select id="category" name="category" 
                  class="w-full p-2 rounded-lg bg-gray-900 border border-gray-700 text-white focus:ring-2 focus:ring-blue-500">
            <option value="">All</option>
            <option value="FixedBills">FixedBills</option>
            <option value="Foodandtravel">Food & Travel</option>
            <option value="Groceries">Groceries</option>
            <option value="Miscellaneous">Misc</option>
            <option value="Salary">Salary</option>
            <option value="Bonus">Bonus</option>
            <option value="Extra">Extra</option>
          </select>
        </div>
        
        <!-- Submit Button -->
        <div class="flex items-end">
          <button type="submit" 
                  class="w-full py-2 bg-blue-600 hover:bg-blue-700 rounded-lg font-medium transition transform hover:scale-105">
            Apply Filters
          </button>
        </div>
      </form>
    </div>

    <!-- 📊 Combined Transactions Table -->
    <div class="glass p-6 rounded-lg">
      <h2 class="text-2xl font-bold mb-4 text-blue-400">Transactions</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-800">
              <th class="p-3 text-left">Type</th>
              <th class="p-3 text-left">Category</th>
              <th class="p-3 text-left">Description</th>
              <th class="p-3 text-left">Amount</th>
              <th class="p-3 text-left">Date</th>
              <th class="p-3 text-left">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (transactions && transactions.length > 0) { %>
              <% transactions.forEach(txn => { %>
                <tr class="border-b border-gray-700 <%= txn.type === 'Income' ? 'text-green-400' : 'text-red-400' %>">
                  <td class="p-3 font-semibold"><%= txn.type %></td>
                  <td class="p-3"><%= txn.category %></td>
                  <td class="p-3"><%= txn.description %></td>
                  <td class="p-3">₹<%= txn.amount %></td>
                  <td class="p-3"><%= txn.date ? new Date(txn.date).toDateString() : "-" %></td>
                  <td class="p-3 flex space-x-2">
                    <% if (txn.type === "Income") { %>
                      <a href="/users/income/edit/<%= txn._id %>" class="px-3 py-1 bg-yellow-500 hover:bg-yellow-600 rounded-md">Edit</a>
                      <form action="/users/income/delete/<%= txn._id %>" method="POST" onsubmit="return confirm('Are you sure?');">
                        <button type="submit" class="px-3 py-1 bg-red-600 hover:bg-red-700 rounded-md">Delete</button>
                      </form>
                    <% } else { %>
                      <a href="/users/expense/edit/<%= txn._id %>" class="px-3 py-1 bg-yellow-500 hover:bg-yellow-600 rounded-md">Edit</a>
                      <form action="/users/expense/delete/<%= txn._id %>" method="POST" onsubmit="return confirm('Are you sure?');">
                        <button type="submit" class="px-3 py-1 bg-red-600 hover:bg-red-700 rounded-md">Delete</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center text-gray-500 py-3">No transactions found</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Back Button -->
    <div class="mt-6">
      <a href="/users/profile" 
         class="block w-full text-center bg-blue-600 hover:bg-blue-700 py-3 rounded-lg font-medium transition transform hover:scale-105">
        Back to Profile
      </a>
    </div>

  </main>

</body>
</html>
